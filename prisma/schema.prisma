generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ AUTH & USER MANAGEMENT ============

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role              String   @default("labour") // super_admin, admin, supervisor, hr_manager, accountant, store_manager, client, labour, vendor, auditor
  isActive          Boolean  @default(true)
  isLocked          Boolean  @default(false)
  lockoutUntil      DateTime?
  failedLoginAttempts Int     @default(0)
  lastLoginAt       DateTime?
  totpSecret    String?
  totpEnabled   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions            Session[]
  auditLogs           AuditLog[]
  approvedLeaveRequests LeaveRequest[] @relation("LeaveApprover")
  projectMembers      ProjectMember[]
  dailyNotes          DailyNote[]
  purchaseRequests    PurchaseRequest[]
  expenses             Expense[]
  notifications       Notification[]
  notificationPrefs    NotificationPreference[]
  issuedAssets        AssetIssue[]
  leaveRequests       LeaveRequest[]
  approvedPurchaseRequests PurchaseRequest[] @relation("PRApprover")
  assignedTasks        ProjectTask[] @relation("TaskAssignee")
  salesInvoices        SalesInvoice[]
  createdBudgets      Budget[] @relation("BudgetCreator")
  approvedBudgets      Budget[] @relation("BudgetApprover")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?
  device       String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // CREATE, UPDATE, DELETE, EXPORT
  entity    String   // model name
  entityId  String?
  oldValues String?  // JSON string
  newValues String?  // JSON string
  ipAddress String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}

// ============ PROJECT MANAGEMENT ============

model Project {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  status        String   @default("planning") // planning, active, on_hold, completed, cancelled
  startDate     DateTime?
  endDate       DateTime?
  budget        Float    @default(0)
  address       String?
  latitude      Float?
  longitude     Float?
  clientId      String?
  progress      Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members      ProjectMember[]
  tasks        ProjectTask[]
  milestones    ProjectMilestone[]
  documents    ProjectDocument[]
  dailyNotes    DailyNote[]
  invoices     Invoice[]
  payments     Payment[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]
  stockMovements   StockMovement[]
  workOrders   WorkOrder[]
  expenses     Expense[]
  boq          BOQ?
  openItems    OpenItem[]
  rfis         RFI[]
  changeEvents ChangeEvent[]
  changeOrders ChangeOrder[]
  commitments  ProjectCommitment[]
  directCosts  DirectCost[]
  primeContract PrimeContract?
  comments     ProjectComment[]
  teamMembers  ProjectTeamMember[]
  projectBudget        Budget?
  resourceAssignments   ResourceAssignment[]
  resourceRequests      ResourceRequest[]
  productivityLogs      ProductivityLog[]
  submittals            Submittal[]
  discussions           Discussion[]
  clientComplaints      ClientComplaint[]

  @@index([status])
  @@index([clientId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member") // manager, supervisor, member
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectTask {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String    @default("todo") // todo, in_progress, completed, cancelled
  priority    String    @default("medium") // low, medium, high, critical
  startDate   DateTime?
  endDate     DateTime?
  progress    Float     @default(0)
  assigneeId  String?
  parentTaskId String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  parentTask ProjectTask? @relation("TaskSubtask", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks  ProjectTask[] @relation("TaskSubtask")

  @@index([projectId])
  @@index([status])
  @@index([assigneeId])
}

model ProjectMilestone {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  dueDate     DateTime?
  status      String    @default("pending") // pending, in_progress, completed, overdue
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectDocument {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String   // drawing, contract, photo, report, other
  filePath  String?
  fileSize  Int?
  mimeType  String?
  uploadedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
}

model DailyNote {
  id          String   @id @default(cuid())
  projectId   String
  date        DateTime
  weather     String?
  temperature Float?
  workDone    String?
  issues      String?
  labourCount Int      @default(0)
  supervisorId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supervisor User    @relation(fields: [supervisorId], references: [id])

  @@index([projectId])
  @@index([date])
}

// ============ FINANCE MODULE ============

model Invoice {
  id          String   @id @default(cuid())
  projectId   String
  invoiceNo   String   @unique
  clientId    String?
  type        String   @default("sales") // sales, purchase
  status      String   @default("draft") // draft, sent, partial, paid, overdue, cancelled
  issueDate   DateTime
  dueDate     DateTime?
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  discount    Float    @default(0)
  total       Float    @default(0)
  paidAmount  Float    @default(0)
  retention   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  payments Payment[]

  @@index([projectId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  description String
  quantity  Float
  unit      String
  unitPrice Float
  amount    Float
  boqItemId String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id          String   @id @default(cuid())
  projectId   String
  invoiceId   String?
  paymentNo   String
  amount      Float
  method      String   // cash, bank_transfer, cheque, online
  status      String   @default("pending") // pending, completed, failed
  reference   String?
  date        DateTime
  receivedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([invoiceId])
  @@index([date])
}

model BOQ {
  id        String   @id @default(cuid())
  projectId String   @unique
  version   Int      @default(1)
  total     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items    BOQItem[]
}

model BOQItem {
  id        String  @id @default(cuid())
  boqId     String
  itemNo    String
  description String
  unit      String
  quantity  Float
  unitRate  Float
  amount    Float

  boq        BOQ          @relation(fields: [boqId], references: [id], onDelete: Cascade)

  @@index([boqId])
}

model Expense {
  id          String   @id @default(cuid())
  projectId   String
  category    String
  description String
  amount      Float
  date        DateTime
  approvedBy  String?
  createdById String
  receipt     String?  // file path
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@index([category])
  @@index([date])
}

model DayBookEntry {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  category    String
  type        String   // income, expense
  amount      Float
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([type])
  @@index([category])
}

// ============ PROCUREMENT MODULE ============

model Supplier {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  contact     String?
  email       String?
  phone       String?
  address     String?
  gstNo       String?
  balance     Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([isActive])
}

model Material {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  unit        String
  category    String?
  description String?
  currentStock Float  @default(0)
  minStock    Float    @default(0)
  unitPrice   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockMovements StockMovement[]

  @@index([name])
}

model StockMovement {
  id          String   @id @default(cuid())
  projectId   String?
  materialId  String
  type        String   // in, out, transfer, adjustment
  quantity    Float
  unitPrice   Float?
  reference   String?
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([materialId])
  @@index([projectId])
  @@index([date])
}

model PurchaseRequest {
  id          String   @id @default(cuid())
  projectId   String
  requestNo   String   @unique
  status      String   @default("draft") // draft, submitted, review, approved, rejected, ordered
  requiredBy  DateTime?
  notes       String?
  createdById String
  approvedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])
  approvedBy User?  @relation("PRApprover", fields: [approvedById], references: [id])
  items     PurchaseRequestItem[]
  purchaseOrder PurchaseOrder?

  @@index([projectId])
  @@index([status])
}

model PurchaseRequestItem {
  id               String  @id @default(cuid())
  purchaseRequestId String
  materialId        String?
  description      String
  quantity         Float
  unit             String
  estimatedPrice   Float?

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model PurchaseOrder {
  id                 String   @id @default(cuid())
  projectId          String
  purchaseRequestId  String?  @unique
  supplierId         String
  orderNo            String   @unique
  status             String   @default("draft") // draft, sent, partially_received, fully_received, billed
  orderDate          DateTime
  expectedDate      DateTime?
  subtotal           Float    @default(0)
  tax                Float    @default(0)
  total              Float    @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier         Supplier         @relation(fields: [supplierId], references: [id])
  purchaseRequest  PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  items            PurchaseOrderItem[]

  @@index([projectId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  materialId      String?
  description     String
  quantity        Float
  receivedQty     Float   @default(0)
  unit            String
  unitPrice       Float
  amount          Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

// ============ LABOUR MANAGEMENT ============

model LabourGroup {
  id        String   @id @default(cuid())
  name      String
  rate      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  labours Labour[]

  @@index([isActive])
}

model Labour {
  id          String   @id @default(cuid())
  groupId     String
  name        String
  phone       String?
  aadhaar     String?
  dailyRate   Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group LabourGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendance  Attendance[]
  payrolls    Payroll[]
  advances    AdvancePayment[]

  @@index([groupId])
  @@index([isActive])
}

model Attendance {
  id          String   @id @default(cuid())
  projectId   String
  labourId    String
  date        DateTime
  status      String   @default("present") // present, absent, half_day, overtime
  hoursWorked Float?
  overtime    Float?
  verifiedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  labour Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@unique([projectId, labourId, date])
  @@index([projectId])
  @@index([labourId])
  @@index([date])
}

model Payroll {
  id          String   @id @default(cuid())
  projectId   String
  labourId    String
  periodStart DateTime
  periodEnd   DateTime
  daysWorked  Int      @default(0)
  overtimeHours Float  @default(0)
  basicPay    Float    @default(0)
  overtimePay Float    @default(0)
  deductions  Float    @default(0)
  advanceDeductions Float @default(0)
  netPay      Float    @default(0)
  status      String   @default("pending") // pending, paid
  paidDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  labour Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([labourId])
  @@index([periodStart])
}

model AdvancePayment {
  id          String   @id @default(cuid())
  labourId    String
  amount      Float
  date        DateTime
  reason      String?
  status      String   @default("pending") // pending, approved, paid, recovered
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  labour Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([labourId])
  @@index([status])
}

// ============ HR MANAGEMENT ============

model Employee {
  id          String   @id @default(cuid())
  userId      String?  @unique
  empCode     String   @unique
  name        String
  email       String?
  phone       String?
  department  String?
  designation String?
  joinDate    DateTime?
  basicSalary Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaveRequests LeaveRequest[]
  loans         Loan[]

  @@index([isActive])
}

model LeaveRequest {
  id        String   @id @default(cuid())
  employeeId String
  userId    String?
  type      String   // sick, casual, earned, maternity, paternity
  startDate DateTime
  endDate   DateTime
  days      Float
  reason    String?
  status    String   @default("pending") // pending, approved, rejected
  approvedById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User?    @relation("LeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([status])
}

model Loan {
  id          String   @id @default(cuid())
  employeeId  String
  amount      Float
  interestRate Float  @default(0)
  tenureMonths Int    @default(0)
  emiAmount   Float    @default(0)
  startDate   DateTime
  status      String   @default("active") // active, completed, default
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

// ============ SUB CONTRACTOR ============

model SubContractor {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  contact   String?
  email     String?
  phone     String?
  address   String?
  gstNo     String?
  balance   Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrders WorkOrder[]

  @@index([isActive])
}

model WorkOrder {
  id              String   @id @default(cuid())
  projectId       String
  subContractorId String
  orderNo         String
  description     String
  totalAmount     Float
  retentionPercent Float   @default(10)
  status          String   @default("draft") // draft, active, partial, complete, closed
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subContractor SubContractor @relation(fields: [subContractorId], references: [id], onDelete: Cascade)
  milestones    MilestonePayment[]

  @@index([projectId])
  @@index([subContractorId])
  @@index([status])
}

model MilestonePayment {
  id              String   @id @default(cuid())
  workOrderId     String
  description     String
  amount          Float
  retention       Float    @default(0)
  netAmount       Float
  dueDate         DateTime?
  paidDate        DateTime?
  status          String   @default("pending") // pending, paid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([status])
}

// ============ ASSET MANAGEMENT ============

model Asset {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String   // tool, vehicle, equipment
  category    String?
  purchaseDate DateTime?
  purchasePrice Float
  currentValue  Float
  status      String   @default("available") // available, issued, maintenance, disposed
  location    String?
  qrCode      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  issues       AssetIssue[]
  maintenance  AssetMaintenance[]

  @@index([type])
  @@index([status])
}

model AssetIssue {
  id          String   @id @default(cuid())
  assetId     String
  issuedTo    String
  issuedById  String
  issuedDate  DateTime
  returnDate  DateTime?
  status      String   @default("issued") // issued, returned, overdue
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  asset     Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  issuedBy User  @relation(fields: [issuedById], references: [id])

  @@index([assetId])
  @@index([status])
}

model AssetMaintenance {
  id          String   @id @default(cuid())
  assetId     String
  type        String   // preventive, corrective, emergency
  description String
  cost        Float    @default(0)
  date        DateTime
  vendor      String?
  status      String   @default("pending") // pending, in_progress, completed
  completedDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([status])
}

// ============ PRODUCT SALES ============

model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([isActive])
}

model Product {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  sku         String   @unique
  brand       String?
  description String?
  unit        String   @default("pcs")
  costPrice   Float    @default(0)
  sellingPrice Float   @default(0)
  currentStock Float   @default(0)
  minStock    Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([isActive])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  gstNo     String?
  balance   Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesInvoices SalesInvoice[]

  @@index([isActive])
}

model SalesQuotation {
  id          String   @id @default(cuid())
  quoteNo     String   @unique
  customerId  String
  validUntil  DateTime
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)
  status      String   @default("draft") // draft, sent, accepted, rejected, expired
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model SalesInvoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  customerId  String?
  quotationId String?
  userId      String?
  invoiceDate DateTime
  dueDate     DateTime?
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)
  paidAmount  Float    @default(0)
  status      String   @default("draft") // draft, sent, partial, paid, overdue, cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // task, payment, invoice, approval, reminder, system
  title     String
  message   String
  data      String?  // JSON
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  inApp      Boolean  @default(true)
  email      Boolean  @default(true)
  sms        Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ PROJECT COLLABORATION MODULE ============

model ProjectTeamMember {
  id        String   @id @default(cuid())
  projectId String
  name      String
  role      String   // owner, project_manager, site_engineer, supervisor, consultant, architect, qs, contractor, subcontractor, client_rep
  company   String?
  phone     String?
  email     String?
  photo     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model OpenItem {
  id          String   @id @default(cuid())
  projectId   String
  itemNo      String
  title       String
  description String?
  category    String   // rfi, site_issue, safety_issue, material_request, client_request, approval_required, change_request
  priority    String   @default("medium") // low, medium, high, critical
  status      String   @default("open") // open, pending, in_review, resolved, closed
  assignedTo  String?
  dueDate     DateTime?
  resolvedDate DateTime?
  resolvedById String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
  @@index([status])
  @@index([dueDate])
}

model RFI {
  id            String   @id @default(cuid())
  projectId     String
  rfiNo         String
  title         String
  description   String
  category      String   // general, technical, commercial, design
  priority      String   @default("medium")
  status        String   @default("draft") // draft, submitted, under_review, answered, closed
  submittedById String
  assignedTo    String?
  dueDate       DateTime?
  answeredById  String?
  answeredAt    DateTime?
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments RFIComment[]

  @@index([projectId])
  @@index([status])
  @@index([category])
}

model RFIComment {
  id        String   @id @default(cuid())
  rfiId     String
  userId    String
  content   String
  createdAt DateTime @default(now())

  rfi RFI @relation(fields: [rfiId], references: [id], onDelete: Cascade)

  @@index([rfiId])
}

model ChangeEvent {
  id          String   @id @default(cuid())
  projectId   String
  eventNo     String
  title       String
  description String?
  category    String   // scope, design, schedule, commercial, quality
  impactType  String   // cost, schedule, scope, quality
  potentialCostImpact   Float  @default(0)
  potentialScheduleImpact String? // e.g. "14 days"
  status      String   @default("draft") // draft, open, review, approved, rejected
  submittedById String
  reviewedById   String?
  approvedById   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeOrders ChangeOrder[]

  @@index([projectId])
  @@index([status])
}

model ChangeOrder {
  id              String   @id @default(cuid())
  projectId       String
  changeEventId   String?
  coNo            String
  title           String
  description     String?
  costAdjustment  Float    @default(0)
  timeAdjustment  String?
  originalBudget  Float    @default(0)
  adjustedBudget  Float    @default(0)
  status          String   @default("draft") // draft, submitted, approved, rejected, executed
  submittedById   String
  approvedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeEvent ChangeEvent? @relation(fields: [changeEventId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
}

model ProjectCommitment {
  id            String   @id @default(cuid())
  projectId     String
  type          String   // purchase_order, subcontract, material_order, labour_contract
  vendor        String
  description   String?
  contractValue Float    @default(0)
  committedCost Float   @default(0)
  remainingCost Float   @default(0)
  status        String   @default("draft") // draft, active, completed, cancelled
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model DirectCost {
  id          String   @id @default(cuid())
  projectId   String
  category    String   // labour, materials, equipment, fuel, transportation, accommodation, rental, subcontractor, miscellaneous
  description String
  amount      Float
  date        DateTime
  approvedById String?
  receipt     String?
  status      String   @default("pending") // pending, approved, rejected
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
  @@index([date])
}

model PrimeContract {
  id            String   @id @default(cuid())
  projectId     String   @unique
  contractNo    String
  client        String
  originalValue Float    @default(0)
  variationOrders Float  @default(0)
  retention     Float    @default(0)  // percentage
  claims        Float    @default(0)
  status        String   @default("active") // draft, active, completed, terminated
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  entityType String // rfi, task, change_order, issue, document, general
  entityId   String?
  content   String
  mentions  String?  // JSON array of user IDs
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

// ============ COST MANAGEMENT & BUDGET CONTROL ============

model CostCode {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  level       Int       @default(1)  // 1=Division, 2=Category, 3=Subcategory, 4=Line Item
  parentId    String?
  description String?
  unitType    String?   // ls (lump sum), ea, sqm, sqft, m, rmt, kg, cum, etc.
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      CostCode?           @relation("CostCodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    CostCode[]         @relation("CostCodeHierarchy")
  budgetItems BudgetLineItem[]

  @@index([parentId])
  @@index([level])
  @@index([isActive])
  @@index([sortOrder])
}

model Budget {
  id                String   @id @default(cuid())
  projectId         String   @unique
  originalValue     Float    @default(0)
  revisedValue      Float    @default(0)
  approvedChanges   Float    @default(0)
  pendingChanges    Float    @default(0)
  retentionPercent  Float    @default(10)
  retentionReleased Float    @default(0)
  status            String   @default("draft") // draft, approved, locked, closed
  createdById       String
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy          User              @relation("BudgetCreator", fields: [createdById], references: [id])
  approvedBy         User?             @relation("BudgetApprover", fields: [approvedById], references: [id])
  lineItems         BudgetLineItem[]
  changeOrders      BudgetChangeOrder[]
  snapshots         BudgetSnapshot[]

  @@index([projectId])
  @@index([status])
}

model BudgetLineItem {
  id              String   @id @default(cuid())
  budgetId        String
  costCodeId      String
  originalBudget  Float    @default(0)
  revisedBudget   Float    @default(0)
  committedCost   Float    @default(0)
  actualCost      Float    @default(0)
  forecastToComplete Float  @default(0)
  estimatedAtCompletion Float @default(0)
  percentComplete Float    @default(0)
  earnedRevenue   Float    @default(0)
  billedRevenue   Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget          Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  costCode        CostCode @relation(fields: [costCodeId], references: [id])

  @@index([budgetId])
  @@index([costCodeId])
}

model BudgetChangeOrder {
  id              String   @id @default(cuid())
  budgetId        String
  bcoNo           String
  title           String
  description     String?
  reason          String?
  originalBudget  Float    @default(0)
  changeAmount    Float    @default(0)
  newBudget       Float    @default(0)
  status          String   @default("draft") // draft, submitted, reviewed, approved, rejected, applied
  submittedById   String
  reviewedById    String?
  approvedById    String?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  appliedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget          Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  lineItemUpdates BudgetLineItemUpdate[]

  @@index([budgetId])
  @@index([status])
}

model BudgetLineItemUpdate {
  id                    String   @id @default(cuid())
  budgetChangeOrderId   String
  budgetLineItemId      String
  previousAmount        Float    @default(0)
  newAmount             Float    @default(0)
  changeAmount          Float    @default(0)

  budgetChangeOrder     BudgetChangeOrder @relation(fields: [budgetChangeOrderId], references: [id], onDelete: Cascade)

  @@index([budgetChangeOrderId])
  @@index([budgetLineItemId])
}

model BudgetSnapshot {
  id              String   @id @default(cuid())
  budgetId        String
  name            String
  snapshotType    String   // original, monthly, current, custom
  totalBudget     Float    @default(0)
  totalActual     Float    @default(0)
  totalCommitted  Float    @default(0)
  totalForecast   Float    @default(0)
  totalEarned     Float    @default(0)
  totalBilled     Float    @default(0)
  snapshotData    String   // JSON - stores line item snapshot
  createdById     String
  createdAt       DateTime @default(now())

  budget          Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@index([snapshotType])
  @@index([createdAt])
}

// ============ RESOURCE MANAGEMENT ============

model ResourceAssignment {
  id            String    @id @default(cuid())
  projectId     String
  resourceType  String    // labour, employee, equipment, vehicle, tool, subcontractor
  resourceId    String
  resourceName  String
  role          String?
  shift         String    @default("day") // day, night, split
  location      String?
  startDate     DateTime
  endDate       DateTime?
  status        String    @default("active") // active, completed, transferred, cancelled
  dailyCost     Float     @default(0)
  hourlyCost    Float     @default(0)
  notes         String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([resourceType, resourceId])
  @@index([status])
  @@index([startDate])
  @@map("resource_assignments")
}

model ResourceRequest {
  id                     String    @id @default(cuid())
  projectId              String
  requestNo              String
  resourceType           String
  resourceName           String?
  quantity               Int       @default(1)
  trade                  String?
  requiredSkills         String?   // JSON
  startDate              DateTime?
  endDate                DateTime?
  shift                  String    @default("day")
  priority               String    @default("medium") // low, medium, high, critical
  reason                 String?
  status                 String    @default("pending") // pending, supervisor_approved, pm_approved, assigned, rejected, cancelled
  requestedById          String
  supervisorApprovedById String?
  supervisorApprovedAt    DateTime?
  pmApprovedById         String?
  pmApprovedAt           DateTime?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("resource_requests")
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  type        String   // electrical, hvac, mechanical, civil, finishing, maintenance, general
  leaderName  String?
  leaderId    String?
  leaderType  String?   // labour, employee
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members CrewMember[]
  @@map("crews")
}

model CrewMember {
  id          String   @id @default(cuid())
  crewId      String
  workerType  String   // labour, employee
  workerId    String
  workerName  String
  role        String   @default("member") // leader, member, specialist
  joinDate    DateTime @default(now())
  isActive    Boolean  @default(true)

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, workerType, workerId])
  @@map("crew_members")
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?  // trade, certification, software, safety
  description String?
  createdAt   DateTime @default(now())

  workers WorkerSkill[]
  @@map("skills")
}

model WorkerSkill {
  id          String    @id @default(cuid())
  skillId     String
  workerType  String    // labour, employee
  workerId    String
  proficiency String    @default("intermediate") // beginner, intermediate, advanced, expert
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, workerType, workerId])
  @@map("worker_skills")
}

model ProductivityLog {
  id            String    @id @default(cuid())
  projectId     String
  date          DateTime
  resourceType  String    // labour, employee, crew
  resourceId    String?
  crewId        String?
  resourceName  String?
  task          String?
  outputUnit    String?
  outputQty     Float     @default(0)
  hoursWorked   Float     @default(0)
  cost          Float     @default(0)
  quality       String?   // excellent, good, average, poor
  notes         String?
  createdById   String
  createdAt     DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, date])
  @@index([resourceType])
  @@map("productivity_logs")
}

// ============ COLLABORATION - SUBMITTALS ============

model Submittal {
  id              String   @id @default(cuid())
  projectId       String
  submittalNo     String
  title           String
  specification   String?
  category        String   // architectural, structural, mechanical, electrical, plumbing, fire_protection, civil, finish
  priority        String   @default("medium")
  revision        String   @default("0")
  status          String   @default("draft") // draft, submitted, under_review, approved, rejected, returned, for_info
  submittedById   String
  reviewedById    String?
  dueDate         DateTime?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([category])
}

// ============ COLLABORATION - DISCUSSIONS ============

model Discussion {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  category    String   // general, technical, schedule, quality, safety, commercial
  status      String   @default("open") // open, in_progress, resolved, closed
  priority    String   @default("medium")
  createdById String
  assignedTo  String?
  dueDate     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments   DiscussionComment[]

  @@index([projectId])
  @@index([status])
  @@index([category])
}

model DiscussionComment {
  id          String   @id @default(cuid())
  discussionId String
  userId      String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
}

// ============ COLLABORATION - ANNOUNCEMENTS ============

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   // general, safety, schedule_change, policy, achievement, emergency
  priority    String   @default("normal") // low, normal, high, urgent
  targetScope String   @default("all") // all, management, projects, specific_project
  projectId   String?  // used when targetScope is specific_project
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([priority])
  @@index([createdAt])
  @@index([targetScope])
}

// ============ CLIENT PORTAL ============

model ClientComplaint {
  id            String   @id @default(cuid())
  projectId    String
  clientName    String
  subject       String
  description   String
  category      String   // quality, safety, delay, communication, billing, scope_change, other
  severity      String   @default("medium") // low, medium, high, critical
  status        String   @default("open") // open, acknowledged, investigating, resolving, resolved, closed
  assignedTo    String?
  resolvedById  String?
  resolution    String?
  resolutionDate DateTime?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([category])
  @@index([severity])
}

// ============ AI & ANALYTICS ============

model AIInsight {
  id          String   @id @default(cuid())
  projectId   String?
  insightType String   // cost_anomaly, schedule_risk, resource_optimization, budget_forecast, quality_alert, safety_risk
  title       String
  description String
  confidence  Float    @default(0)
  severity    String   @default("info") // info, warning, critical
  recommendations String // JSON array of recommendations
  affectedEntities String? // JSON array of affected entity IDs
  status      String   @default("new") // new, acknowledged, actioned, dismissed
  createdById String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  @@index([projectId])
  @@index([insightType])
  @@index([status])
  @@index([severity])
}

// ============ FEATURE FLAGS & VERSIONING ============

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  module      String
  enabled     Boolean  @default(true)
  isBeta      Boolean  @default(false)
  config      String?  // JSON string for additional config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  title       String
  releaseNotes String
  releasedAt  DateTime @default(now())
  releasedBy  String?
}
