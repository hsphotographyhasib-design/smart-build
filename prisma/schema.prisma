generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AIInsight {
  id               String    @id @default(uuid())
  projectId        String?
  insightType      String
  title            String
  description      String
  confidence       Float     @default(0)
  severity         String    @default("info")
  recommendations  String
  affectedEntities String?
  status           String    @default("new")
  createdById      String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?
  project          Project?  @relation(fields: [projectId], references: [id])
  user             User?     @relation("AIInsight_createdByIdToUser", fields: [createdById], references: [id])

  @@index([severity])
  @@index([status])
  @@index([insightType])
  @@index([projectId])
}

model AdvancePayment {
  id        String   @id @default(uuid())
  labourId  String
  amount    Float
  date      DateTime
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime
  labour    Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([labourId])
}

model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String
  category    String
  priority    String    @default("normal")
  targetScope String    @default("all")
  projectId   String?
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  project     Project?  @relation(fields: [projectId], references: [id])
  user        User      @relation("Announcement_createdByIdToUser", fields: [createdById], references: [id])

  @@index([targetScope])
  @@index([createdAt])
  @@index([priority])
  @@index([category])
}

model Asset {
  id               String             @id @default(uuid())
  name             String
  code             String             @unique
  type             String
  category         String?
  purchaseDate     DateTime?
  purchasePrice    Float
  currentValue     Float
  status           String             @default("available")
  location         String?
  qrCode           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  assetIssue       AssetIssue[]
  assetMaintenance AssetMaintenance[]

  @@index([name])
  @@index([status])
  @@index([type])
}

model AssetIssue {
  id         String    @id @default(uuid())
  assetId    String
  issuedTo   String
  issuedById String
  issuedDate DateTime
  returnDate DateTime?
  status     String    @default("issued")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  user       User @relation(fields: [issuedById], references: [id])
  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assetId])
  @@index([issuedById])
}

model AssetMaintenance {
  id            String    @id @default(uuid())
  assetId       String
  type          String
  description   String
  cost          Float     @default(0)
  date          DateTime
  vendor        String?
  status        String    @default("pending")
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  asset         Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assetId])
}

model Attendance {
  id          String   @id @default(uuid())
  projectId   String
  labourId    String
  date        DateTime
  status      String   @default("present")
  hoursWorked Float?
  overtime    Float?
  verifiedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  labour      Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@unique([projectId, labourId, date])
  @@index([date])
  @@index([labourId])
  @@index([projectId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues String?
  newValues String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([entity])
}

model BOQ {
  id        String    @id @default(uuid())
  projectId String    @unique
  version   Int       @default(1)
  total     Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  boqItem   BOQItem[]

  @@index([projectId])
}

model BOQItem {
  id          String @id @default(uuid())
  boqId       String
  itemNo      String
  description String
  unit        String
  quantity    Float
  unitRate    Float
  amount      Float
  boq         BOQ @relation(fields: [boqId], references: [id], onDelete: Cascade)

  @@index([boqId])
}

model Budget {
  id                             String              @id @default(uuid())
  projectId                      String              @unique
  originalValue                  Float               @default(0)
  revisedValue                   Float               @default(0)
  approvedChanges                Float               @default(0)
  pendingChanges                 Float               @default(0)
  retentionPercent               Float               @default(10)
  retentionReleased              Float               @default(0)
  status                         String              @default("draft")
  createdById                    String
  approvedById                   String?
  approvedAt                     DateTime?
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime
  User_Budget_approvedByIdToUser User?               @relation("Budget_approvedByIdToUser", fields: [approvedById], references: [id])
  User_Budget_createdByIdToUser  User                @relation("Budget_createdByIdToUser", fields: [createdById], references: [id])
  project                        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetChangeOrder              BudgetChangeOrder[]
  budgetLineItem                 BudgetLineItem[]
  budgetSnapshot                 BudgetSnapshot[]

  @@index([status])
  @@index([projectId])
}

model BudgetChangeOrder {
  id                   String                 @id @default(uuid())
  budgetId             String
  bcoNo                String
  title                String
  description          String?
  reason               String?
  originalBudget       Float                  @default(0)
  changeAmount         Float                  @default(0)
  newBudget            Float                  @default(0)
  status               String                 @default("draft")
  submittedById        String
  reviewedById         String?
  approvedById         String?
  reviewedAt           DateTime?
  approvedAt           DateTime?
  appliedAt            DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  budget               Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  budgetLineItemUpdate BudgetLineItemUpdate[]

  @@index([status])
  @@index([budgetId])
}

model BudgetLineItem {
  id                    String   @id @default(uuid())
  budgetId              String
  costCodeId            String
  originalBudget        Float    @default(0)
  revisedBudget         Float    @default(0)
  committedCost         Float    @default(0)
  actualCost            Float    @default(0)
  forecastToComplete    Float    @default(0)
  estimatedAtCompletion Float    @default(0)
  percentComplete       Float    @default(0)
  earnedRevenue         Float    @default(0)
  billedRevenue         Float    @default(0)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  costCode              CostCode @relation(fields: [costCodeId], references: [id])
  budget                Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([costCodeId])
  @@index([budgetId])
}

model BudgetLineItemUpdate {
  id                  String            @id @default(uuid())
  budgetChangeOrderId String
  budgetLineItemId    String
  previousAmount      Float             @default(0)
  newAmount           Float             @default(0)
  changeAmount        Float             @default(0)
  budgetChangeOrder   BudgetChangeOrder @relation(fields: [budgetChangeOrderId], references: [id], onDelete: Cascade)

  @@index([budgetLineItemId])
  @@index([budgetChangeOrderId])
}

model BudgetSnapshot {
  id             String   @id @default(uuid())
  budgetId       String
  name           String
  snapshotType   String
  totalBudget    Float    @default(0)
  totalActual    Float    @default(0)
  totalCommitted Float    @default(0)
  totalForecast  Float    @default(0)
  totalEarned    Float    @default(0)
  totalBilled    Float    @default(0)
  snapshotData   String
  createdById    String
  createdAt      DateTime @default(now())
  user           User     @relation("BudgetSnapshot_createdByIdToUser", fields: [createdById], references: [id])
  budget         Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([snapshotType])
  @@index([budgetId])
}

model ChangeEvent {
  id                      String        @id @default(uuid())
  projectId               String
  eventNo                 String
  title                   String
  description             String?
  category                String
  impactType              String
  potentialCostImpact     Float         @default(0)
  potentialScheduleImpact String?
  status                  String        @default("draft")
  submittedById           String
  reviewedById            String?
  approvedById            String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime
  project                 Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeOrder             ChangeOrder[]

  @@index([status])
  @@index([projectId])
}

model ChangeOrder {
  id             String       @id @default(uuid())
  projectId      String
  changeEventId  String?
  coNo           String
  title          String
  description    String?
  costAdjustment Float        @default(0)
  timeAdjustment String?
  originalBudget Float        @default(0)
  adjustedBudget Float        @default(0)
  status         String       @default("draft")
  submittedById  String
  approvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  changeEvent    ChangeEvent? @relation(fields: [changeEventId], references: [id])
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
}

model ClientComplaint {
  id             String    @id @default(uuid())
  projectId      String
  clientName     String
  subject        String
  description    String
  category       String
  severity       String    @default("medium")
  status         String    @default("open")
  assignedTo     String?
  resolvedById   String?
  resolution     String?
  resolutionDate DateTime?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  user           User      @relation("ClientComplaint_createdByIdToUser", fields: [createdById], references: [id])
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([severity])
  @@index([category])
  @@index([status])
  @@index([projectId])
}

model CostCode {
  id             String           @id @default(uuid())
  code           String           @unique
  name           String
  level          Int              @default(1)
  parentId       String?
  description    String?
  unitType       String?
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  budgetLineItem BudgetLineItem[]
  costCode       CostCode?        @relation("CostCodeToCostCode", fields: [parentId], references: [id], onDelete: Cascade)
  other_CostCode CostCode[]       @relation("CostCodeToCostCode")

  @@index([sortOrder])
  @@index([isActive])
  @@index([level])
  @@index([parentId])
}

model Customer {
  id             String           @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  gstNo          String?
  balance        Float            @default(0)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  salesInvoice   SalesInvoice[]
  salesQuotation SalesQuotation[]

  @@index([isActive])
}

model DailyNote {
  id           String   @id @default(uuid())
  projectId    String
  date         DateTime
  weather      String?
  temperature  Float?
  workDone     String?
  issues       String?
  labourCount  Int      @default(0)
  supervisorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  user         User @relation(fields: [supervisorId], references: [id])
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([projectId])
}

model DayBookEntry {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  category    String
  type        String
  amount      Float
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([category])
  @@index([type])
  @@index([date])
}

model DirectCost {
  id           String   @id @default(uuid())
  projectId    String
  category     String
  description  String
  amount       Float
  date         DateTime
  approvedById String?
  receipt      String?
  status       String   @default("pending")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  user         User     @relation("DirectCost_createdByIdToUser", fields: [createdById], references: [id])
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([category])
  @@index([projectId])
}

model Discussion {
  id                String              @id @default(uuid())
  projectId         String
  title             String
  description       String?
  category          String
  status            String              @default("open")
  priority          String              @default("medium")
  createdById       String
  assignedTo        String?
  dueDate           DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  user              User                @relation("Discussion_createdByIdToUser", fields: [createdById], references: [id])
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  discussionComment DiscussionComment[]

  @@index([category])
  @@index([status])
  @@index([projectId])
}

model DiscussionComment {
  id           String     @id @default(uuid())
  discussionId String
  userId       String
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
}

model Employee {
  id           String         @id @default(uuid())
  userId       String?        @unique
  empCode      String         @unique
  name         String
  email        String?
  phone        String?
  department   String?
  designation  String?
  joinDate     DateTime?
  basicSalary  Float
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  leaveRequest LeaveRequest[]
  loan         Loan[]

  @@index([isActive])
}

model Expense {
  id          String   @id @default(uuid())
  projectId   String
  category    String
  description String
  amount      Float
  date        DateTime
  approvedBy  String?
  createdById String
  receipt     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  user        User @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([category])
  @@index([projectId])
  @@index([createdById])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  module      String
  enabled     Boolean  @default(true)
  isBeta      Boolean  @default(false)
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Invoice {
  id          String        @id @default(uuid())
  projectId   String
  invoiceNo   String        @unique
  clientId    String?
  type        String        @default("sales")
  status      String        @default("draft")
  issueDate   DateTime
  dueDate     DateTime?
  subtotal    Float         @default(0)
  tax         Float         @default(0)
  discount    Float         @default(0)
  total       Float         @default(0)
  paidAmount  Float         @default(0)
  retention   Float         @default(0)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoiceItem InvoiceItem[]
  payment     Payment[]

  @@index([issueDate])
  @@index([status])
  @@index([projectId])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float
  unit        String
  unitPrice   Float
  amount      Float
  boqItemId   String?
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Labour {
  id             String           @id @default(uuid())
  groupId        String
  name           String
  phone          String?
  aadhaar        String?
  dailyRate      Float
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  advancePayment AdvancePayment[]
  attendance     Attendance[]
  labourGroup    LabourGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payroll        Payroll[]

  @@index([isActive])
  @@index([groupId])
}

model LabourGroup {
  id        String   @id @default(uuid())
  name      String
  rate      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  labour    Labour[]

  @@index([isActive])
}

model LeaveRequest {
  id                                   String   @id @default(uuid())
  employeeId                           String
  userId                               String?
  type                                 String
  startDate                            DateTime
  endDate                              DateTime
  days                                 Float
  reason                               String?
  status                               String   @default("pending")
  approvedById                         String?
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime
  User_LeaveRequest_approvedByIdToUser User?    @relation("LeaveRequest_approvedByIdToUser", fields: [approvedById], references: [id])
  User_LeaveRequest_userIdToUser       User?    @relation("LeaveRequest_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
  employee                             Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([employeeId])
}

model Loan {
  id           String   @id @default(uuid())
  employeeId   String
  amount       Float
  interestRate Float    @default(0)
  tenureMonths Int      @default(0)
  emiAmount    Float    @default(0)
  startDate    DateTime
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([employeeId])
}

model Material {
  id            String          @id @default(uuid())
  name          String
  code          String          @unique
  unit          String
  category      String?
  description   String?
  currentStock  Float           @default(0)
  minStock      Float           @default(0)
  unitPrice     Float           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  stockMovement StockMovement[]

  @@index([name])
}

model MilestonePayment {
  id          String    @id @default(uuid())
  workOrderId String
  description String
  amount      Float
  retention   Float     @default(0)
  netAmount   Float
  dueDate     DateTime?
  paidDate    DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([workOrderId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([userId])
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  inApp     Boolean  @default(true)
  email     Boolean  @default(true)
  sms       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OpenItem {
  id           String    @id @default(uuid())
  projectId    String
  itemNo       String
  title        String
  description  String?
  category     String
  priority     String    @default("medium")
  status       String    @default("open")
  assignedTo   String?
  dueDate      DateTime?
  resolvedDate DateTime?
  resolvedById String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  user         User      @relation("OpenItem_createdByIdToUser", fields: [createdById], references: [id])
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([status])
  @@index([category])
  @@index([projectId])
}

model Payment {
  id         String   @id @default(uuid())
  projectId  String
  invoiceId  String?
  paymentNo  String
  amount     Float
  method     String
  status     String   @default("pending")
  reference  String?
  date       DateTime
  receivedBy String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([invoiceId])
  @@index([projectId])
}

model Payroll {
  id                String    @id @default(uuid())
  projectId         String
  labourId          String
  periodStart       DateTime
  periodEnd         DateTime
  daysWorked        Int       @default(0)
  overtimeHours     Float     @default(0)
  basicPay          Float     @default(0)
  overtimePay       Float     @default(0)
  deductions        Float     @default(0)
  advanceDeductions Float     @default(0)
  netPay            Float     @default(0)
  status            String    @default("pending")
  paidDate          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  labour            Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([periodStart])
  @@index([labourId])
  @@index([projectId])
}

model PrimeContract {
  id              String    @id @default(uuid())
  projectId       String    @unique
  contractNo      String
  client          String
  originalValue   Float     @default(0)
  variationOrders Float     @default(0)
  retention       Float     @default(0)
  claims          Float     @default(0)
  status          String    @default("active")
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
}

model Product {
  id              String          @id @default(uuid())
  categoryId      String
  name            String
  sku             String          @unique
  brand           String?
  description     String?
  unit            String          @default("pcs")
  costPrice       Float           @default(0)
  sellingPrice    Float           @default(0)
  currentStock    Float           @default(0)
  minStock        Float           @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  productCategory ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([categoryId])
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  product   Product[]

  @@index([isActive])
}

model Project {
  id                   String                 @id @default(uuid())
  name                 String
  code                 String                 @unique
  description          String?
  status               String                 @default("planning")
  startDate            DateTime?
  endDate              DateTime?
  budget               Float                  @default(0)
  address              String?
  latitude             Float?
  longitude            Float?
  clientId             String?
  progress             Float                  @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  aiInsight            AIInsight[]
  announcement         Announcement[]
  BOQ                  BOQ?
  budgetData           Budget?
  changeEvent          ChangeEvent[]
  changeOrder          ChangeOrder[]
  clientComplaint      ClientComplaint[]
  dailyNote            DailyNote[]
  directCost           DirectCost[]
  discussion           Discussion[]
  expense              Expense[]
  invoice              Invoice[]
  openItem             OpenItem[]
  payment              Payment[]
  primeContract        PrimeContract?
  projectComment       ProjectComment[]
  projectCommitment    ProjectCommitment[]
  projectDocument      ProjectDocument[]
  projectMember        ProjectMember[]
  projectMilestone     ProjectMilestone[]
  projectTask          ProjectTask[]
  projectTeamMember    ProjectTeamMember[]
  purchaseOrder        PurchaseOrder[]
  purchaseRequest      PurchaseRequest[]
  rfi                  RFI[]
  stockMovement        StockMovement[]
  submittal            Submittal[]
  workOrder            WorkOrder[]
  productivity_logs    productivity_logs[]
  resource_assignments resource_assignments[]
