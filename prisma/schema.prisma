// ============ WHATSAPP INTEGRATION MODELS ============

model WhatsAppAccount {
  id                String   @id @default(uuid())
  phoneNumber       String   @unique
  name              String
  sessionId         String?  @unique  // OpenWA session ID
  status            String   @default("disconnected")  // connected, disconnected, scanning
  qrCode            String?             // Base64 QR code for scanning
  lastSyncAt        DateTime?
  isActive          Boolean  @default(true)
  isEnabled         Boolean  @default(true)
  accessToken       String?             // Meta Cloud API token (optional; OpenWA uses sessionId)
  phoneNumberId     String?             // Meta Cloud API phone number id (optional)
  maxDailyMessages  Int      @default(1000)
  businessName      String?
  pushName          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  conversations    WhatsAppConversation[]
  sentMessages      WhatsAppMessage[]     @relation("SentMessages")
  receivedMessages  WhatsAppMessage[]     @relation("ReceivedMessages")
  templates         WhatsAppMessageTemplate[]
  departments       WhatsAppDepartment[]
}

model WhatsAppContact {
  id              String   @id @default(uuid())
  waId            String   @unique              // WhatsApp ID (e.g., "628123456789@c.us")
  phoneNumber     String
  name            String?
  pushName        String?
  profilePicUrl   String?
  isBusiness      Boolean  @default(false)
  isBlocked       Boolean  @default(false)
  tags            String?                            // JSON array of tags
  notes           String? @db.Text
  customerId      String?
  lastSeenAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  customer              Customer?              @relation(fields: [customerId], references: [id])
  messages              WhatsAppMessage[]      @relation("ContactMessages")
  ticket                MaintenanceTicket?     @relation("TicketContact")
  conversations         WhatsAppConversation[]

  @@index([customerId])
}

model WhatsAppConversation {
  id              String   @id @default(uuid())
  waChatId        String                          // WhatsApp chat ID
  contactId       String
  accountId       String
  lastMessageAt   DateTime?
  lastMessageText String?
  lastMessageType String?
  unreadCount     Int      @default(0)
  status          String   @default("open")        // open, closed, pending
  priority        String   @default("normal")       // low, normal, high, urgent
  assignedToId    String?
  assignedAt      DateTime?
  isGroup         Boolean  @default(false)
  groupName       String?
  isArchived      Boolean  @default(false)
  internalNotes   String? @db.Text
  tags            String?                          // JSON array of tags
  ticketId        String?                          // denormalized link to MaintenanceTicket
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contact         WhatsAppContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  account         WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assignedTo      User?            @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages        WhatsAppMessage[]
  complaintLink   ComplaintWhatsAppLink?
  ticket          MaintenanceTicket? @relation("TicketConversation")

  @@index([contactId])
  @@index([accountId])
  @@index([assignedToId])
  @@index([status])
  @@index([lastMessageAt])
  @@index([waChatId])
}

model WhatsAppMessage {
  id              String   @id @default(uuid())
  waMessageId     String?
  conversationId  String
  contactId       String?
  sentByAccountId     String?
  receivedByAccountId String?
  direction       String                          // incoming, outgoing
  messageType     String   @default("text")       // text, image, video, audio, document, location, contact, sticker, interactive, template, system, deleted
  content         String? @db.Text
  mediaType       String?                         // image/jpeg, video/mp4, etc.
  fileName        String?
  fileSize        Int?
  caption         String?
  thumbnailUrl    String?
  location        String?                         // JSON { lat, lng, address }
