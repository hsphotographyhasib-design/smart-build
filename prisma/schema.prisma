generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AIInsight {
  id               String    @id
  projectId        String?
  insightType      String
  title            String
  description      String
  confidence       Float     @default(0)
  severity         String    @default("info")
  recommendations  String
  affectedEntities String?
  status           String    @default("new")
  createdById      String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?

  @@index([severity])
  @@index([status])
  @@index([insightType])
  @@index([projectId])
}

model AdvancePayment {
  id        String   @id
  labourId  String
  amount    Float
  date      DateTime
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime
  Labour    Labour   @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([labourId])
}

model Announcement {
  id          String    @id
  title       String
  content     String
  category    String
  priority    String    @default("normal")
  targetScope String    @default("all")
  projectId   String?
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime

  @@index([targetScope])
  @@index([createdAt])
  @@index([priority])
  @@index([category])
}

model Asset {
  id               String             @id
  name             String
  code             String             @unique
  type             String
  category         String?
  purchaseDate     DateTime?
  purchasePrice    Float
  currentValue     Float
  status           String             @default("available")
  location         String?
  qrCode           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  AssetIssue       AssetIssue[]
  AssetMaintenance AssetMaintenance[]

  @@index([status])
  @@index([type])
}

model AssetIssue {
  id         String    @id
  assetId    String
  issuedTo   String
  issuedById String
  issuedDate DateTime
  returnDate DateTime?
  status     String    @default("issued")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  User       User      @relation(fields: [issuedById], references: [id])
  Asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assetId])
}

model AssetMaintenance {
  id            String    @id
  assetId       String
  type          String
  description   String
  cost          Float     @default(0)
  date          DateTime
  vendor        String?
  status        String    @default("pending")
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assetId])
}

model Attendance {
  id          String   @id
  projectId   String
  labourId    String
  date        DateTime
  status      String   @default("present")
  hoursWorked Float?
  overtime    Float?
  verifiedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Labour      Labour   @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@unique([projectId, labourId, date])
  @@index([date])
  @@index([labourId])
  @@index([projectId])
}

model AuditLog {
  id        String   @id
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues String?
  newValues String?
  ipAddress String?
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([entity])
}

model BOQ {
  id        String    @id
  projectId String    @unique
  version   Int       @default(1)
  total     Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  BOQItem   BOQItem[]
}

model BOQItem {
  id          String @id
  boqId       String
  itemNo      String
  description String
  unit        String
  quantity    Float
  unitRate    Float
  amount      Float
  BOQ         BOQ    @relation(fields: [boqId], references: [id], onDelete: Cascade)

  @@index([boqId])
}

model Budget {
  id                             String              @id
  projectId                      String              @unique
  originalValue                  Float               @default(0)
  revisedValue                   Float               @default(0)
  approvedChanges                Float               @default(0)
  pendingChanges                 Float               @default(0)
  retentionPercent               Float               @default(10)
  retentionReleased              Float               @default(0)
  status                         String              @default("draft")
  createdById                    String
  approvedById                   String?
  approvedAt                     DateTime?
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime
  User_Budget_approvedByIdToUser User?               @relation("Budget_approvedByIdToUser", fields: [approvedById], references: [id])
  User_Budget_createdByIdToUser  User                @relation("Budget_createdByIdToUser", fields: [createdById], references: [id])
  Project                        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  BudgetChangeOrder              BudgetChangeOrder[]
  BudgetLineItem                 BudgetLineItem[]
  BudgetSnapshot                 BudgetSnapshot[]

  @@index([status])
  @@index([projectId])
}

model BudgetChangeOrder {
  id                   String                 @id
  budgetId             String
  bcoNo                String
  title                String
  description          String?
  reason               String?
  originalBudget       Float                  @default(0)
  changeAmount         Float                  @default(0)
  newBudget            Float                  @default(0)
  status               String                 @default("draft")
  submittedById        String
  reviewedById         String?
  approvedById         String?
  reviewedAt           DateTime?
  approvedAt           DateTime?
  appliedAt            DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  Budget               Budget                 @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  BudgetLineItemUpdate BudgetLineItemUpdate[]

  @@index([status])
  @@index([budgetId])
}

model BudgetLineItem {
  id                    String   @id
  budgetId              String
  costCodeId            String
  originalBudget        Float    @default(0)
  revisedBudget         Float    @default(0)
  committedCost         Float    @default(0)
  actualCost            Float    @default(0)
  forecastToComplete    Float    @default(0)
  estimatedAtCompletion Float    @default(0)
  percentComplete       Float    @default(0)
  earnedRevenue         Float    @default(0)
  billedRevenue         Float    @default(0)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  CostCode              CostCode @relation(fields: [costCodeId], references: [id])
  Budget                Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([costCodeId])
  @@index([budgetId])
}

model BudgetLineItemUpdate {
  id                  String            @id
  budgetChangeOrderId String
  budgetLineItemId    String
  previousAmount      Float             @default(0)
  newAmount           Float             @default(0)
  changeAmount        Float             @default(0)
  BudgetChangeOrder   BudgetChangeOrder @relation(fields: [budgetChangeOrderId], references: [id], onDelete: Cascade)

  @@index([budgetLineItemId])
  @@index([budgetChangeOrderId])
}

model BudgetSnapshot {
  id             String   @id
  budgetId       String
  name           String
  snapshotType   String
  totalBudget    Float    @default(0)
  totalActual    Float    @default(0)
  totalCommitted Float    @default(0)
  totalForecast  Float    @default(0)
  totalEarned    Float    @default(0)
  totalBilled    Float    @default(0)
  snapshotData   String
  createdById    String
  createdAt      DateTime @default(now())
  Budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([snapshotType])
  @@index([budgetId])
}

model ChangeEvent {
  id                      String        @id
  projectId               String
  eventNo                 String
  title                   String
  description             String?
  category                String
  impactType              String
  potentialCostImpact     Float         @default(0)
  potentialScheduleImpact String?
  status                  String        @default("draft")
  submittedById           String
  reviewedById            String?
  approvedById            String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime
  Project                 Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ChangeOrder             ChangeOrder[]

  @@index([status])
  @@index([projectId])
}

model ChangeOrder {
  id             String       @id
  projectId      String
  changeEventId  String?
  coNo           String
  title          String
  description    String?
  costAdjustment Float        @default(0)
  timeAdjustment String?
  originalBudget Float        @default(0)
  adjustedBudget Float        @default(0)
  status         String       @default("draft")
  submittedById  String
  approvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  ChangeEvent    ChangeEvent? @relation(fields: [changeEventId], references: [id])
  Project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
}

model ClientComplaint {
  id             String    @id
  projectId      String
  clientName     String
  subject        String
  description    String
  category       String
  severity       String    @default("medium")
  status         String    @default("open")
  assignedTo     String?
  resolvedById   String?
  resolution     String?
  resolutionDate DateTime?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  Project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([severity])
  @@index([category])
  @@index([status])
  @@index([projectId])
}

model CostCode {
  id             String           @id
  code           String           @unique
  name           String
  level          Int              @default(1)
  parentId       String?
  description    String?
  unitType       String?
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  BudgetLineItem BudgetLineItem[]
  CostCode       CostCode?        @relation("CostCodeToCostCode", fields: [parentId], references: [id], onDelete: Cascade)
  other_CostCode CostCode[]       @relation("CostCodeToCostCode")

  @@index([sortOrder])
  @@index([isActive])
  @@index([level])
  @@index([parentId])
}

model Customer {
  id           String         @id
  name         String
  email        String?
  phone        String?
  address      String?
  gstNo        String?
  balance      Float          @default(0)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  SalesInvoice SalesInvoice[]

  @@index([isActive])
}

model DailyNote {
  id           String   @id
  projectId    String
  date         DateTime
  weather      String?
  temperature  Float?
  workDone     String?
  issues       String?
  labourCount  Int      @default(0)
  supervisorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  User         User     @relation(fields: [supervisorId], references: [id])
  Project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([projectId])
}

model DayBookEntry {
  id          String   @id
  date        DateTime
  description String
  category    String
  type        String
  amount      Float
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([category])
  @@index([type])
  @@index([date])
}

model DirectCost {
  id           String   @id
  projectId    String
  category     String
  description  String
  amount       Float
  date         DateTime
  approvedById String?
  receipt      String?
  status       String   @default("pending")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  Project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([category])
  @@index([projectId])
}

model Discussion {
  id                String              @id
  projectId         String
  title             String
  description       String?
  category          String
  status            String              @default("open")
  priority          String              @default("medium")
  createdById       String
  assignedTo        String?
  dueDate           DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  Project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  DiscussionComment DiscussionComment[]

  @@index([category])
  @@index([status])
  @@index([projectId])
}

model DiscussionComment {
  id           String     @id
  discussionId String
  userId       String
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
}

model Employee {
  id           String         @id
  userId       String?        @unique
  empCode      String         @unique
  name         String
  email        String?
  phone        String?
  department   String?
  designation  String?
  joinDate     DateTime?
  basicSalary  Float
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  LeaveRequest LeaveRequest[]
  Loan         Loan[]

  @@index([isActive])
}

model Expense {
  id          String   @id
  projectId   String
  category    String
  description String
  amount      Float
  date        DateTime
  approvedBy  String?
  createdById String
  receipt     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [createdById], references: [id])
  Project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([category])
  @@index([projectId])
}

model FeatureFlag {
  id          String   @id
  key         String   @unique
  name        String
  description String?
  module      String
  enabled     Boolean  @default(true)
  isBeta      Boolean  @default(false)
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Invoice {
  id          String        @id
  projectId   String
  invoiceNo   String        @unique
  clientId    String?
  type        String        @default("sales")
  status      String        @default("draft")
  issueDate   DateTime
  dueDate     DateTime?
  subtotal    Float         @default(0)
  tax         Float         @default(0)
  discount    Float         @default(0)
  total       Float         @default(0)
  paidAmount  Float         @default(0)
  retention   Float         @default(0)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  Project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  InvoiceItem InvoiceItem[]
  Payment     Payment[]

  @@index([issueDate])
  @@index([status])
  @@index([projectId])
}

model InvoiceItem {
  id          String  @id
  invoiceId   String
  description String
  quantity    Float
  unit        String
  unitPrice   Float
  amount      Float
  boqItemId   String?
  Invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Labour {
  id             String           @id
  groupId        String
  name           String
  phone          String?
  aadhaar        String?
  dailyRate      Float
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  AdvancePayment AdvancePayment[]
  Attendance     Attendance[]
  LabourGroup    LabourGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Payroll        Payroll[]

  @@index([isActive])
  @@index([groupId])
}

model LabourGroup {
  id        String   @id
  name      String
  rate      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Labour    Labour[]

  @@index([isActive])
}

model LeaveRequest {
  id                                   String   @id
  employeeId                           String
  userId                               String?
  type                                 String
  startDate                            DateTime
  endDate                              DateTime
  days                                 Float
  reason                               String?
  status                               String   @default("pending")
  approvedById                         String?
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime
  User_LeaveRequest_approvedByIdToUser User?    @relation("LeaveRequest_approvedByIdToUser", fields: [approvedById], references: [id])
  User_LeaveRequest_userIdToUser       User?    @relation("LeaveRequest_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
  Employee                             Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([employeeId])
}

model Loan {
  id           String   @id
  employeeId   String
  amount       Float
  interestRate Float    @default(0)
  tenureMonths Int      @default(0)
  emiAmount    Float    @default(0)
  startDate    DateTime
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  Employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([employeeId])
}

model Material {
  id            String          @id
  name          String
  code          String          @unique
  unit          String
  category      String?
  description   String?
  currentStock  Float           @default(0)
  minStock      Float           @default(0)
  unitPrice     Float           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  StockMovement StockMovement[]

  @@index([name])
}

model MilestonePayment {
  id          String    @id
  workOrderId String
  description String
  amount      Float
  retention   Float     @default(0)
  netAmount   Float
  dueDate     DateTime?
  paidDate    DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  WorkOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([workOrderId])
}

model Notification {
  id        String   @id
  userId    String
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([userId])
}

model NotificationPreference {
  id        String   @id
  userId    String   @unique
  inApp     Boolean  @default(true)
  email     Boolean  @default(true)
  sms       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OpenItem {
  id           String    @id
  projectId    String
  itemNo       String
  title        String
  description  String?
  category     String
  priority     String    @default("medium")
  status       String    @default("open")
  assignedTo   String?
  dueDate      DateTime?
  resolvedDate DateTime?
  resolvedById String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  Project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([status])
  @@index([category])
  @@index([projectId])
}

model Payment {
  id         String   @id
  projectId  String
  invoiceId  String?
  paymentNo  String
  amount     Float
  method     String
  status     String   @default("pending")
  reference  String?
  date       DateTime
  receivedBy String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  Project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([invoiceId])
  @@index([projectId])
}

model Payroll {
  id                String    @id
  projectId         String
  labourId          String
  periodStart       DateTime
  periodEnd         DateTime
  daysWorked        Int       @default(0)
  overtimeHours     Float     @default(0)
  basicPay          Float     @default(0)
  overtimePay       Float     @default(0)
  deductions        Float     @default(0)
  advanceDeductions Float     @default(0)
  netPay            Float     @default(0)
  status            String    @default("pending")
  paidDate          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  Labour            Labour    @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([periodStart])
  @@index([labourId])
  @@index([projectId])
}

model PrimeContract {
  id              String    @id
  projectId       String    @unique
  contractNo      String
  client          String
  originalValue   Float     @default(0)
  variationOrders Float     @default(0)
  retention       Float     @default(0)
  claims          Float     @default(0)
  status          String    @default("active")
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  Project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Product {
  id              String          @id
  categoryId      String
  name            String
  sku             String          @unique
  brand           String?
  description     String?
  unit            String          @default("pcs")
  costPrice       Float           @default(0)
  sellingPrice    Float           @default(0)
  currentStock    Float           @default(0)
  minStock        Float           @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  ProductCategory ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([categoryId])
}

model ProductCategory {
  id        String    @id
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Product   Product[]

  @@index([isActive])
}

model Project {
  id                   String                 @id
  name                 String
  code                 String                 @unique
  description          String?
  status               String                 @default("planning")
  startDate            DateTime?
  endDate              DateTime?
  budget               Float                  @default(0)
  address              String?
  latitude             Float?
  longitude            Float?
  clientId             String?
  progress             Float                  @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  BOQ                  BOQ?
  Budget               Budget?
  ChangeEvent          ChangeEvent[]
  ChangeOrder          ChangeOrder[]
  ClientComplaint      ClientComplaint[]
  DailyNote            DailyNote[]
  DirectCost           DirectCost[]
  Discussion           Discussion[]
  Expense              Expense[]
  Invoice              Invoice[]
  OpenItem             OpenItem[]
  Payment              Payment[]
  PrimeContract        PrimeContract?
  ProjectComment       ProjectComment[]
  ProjectCommitment    ProjectCommitment[]
  ProjectDocument      ProjectDocument[]
  ProjectMember        ProjectMember[]
  ProjectMilestone     ProjectMilestone[]
  ProjectTask          ProjectTask[]
  ProjectTeamMember    ProjectTeamMember[]
  PurchaseOrder        PurchaseOrder[]
  PurchaseRequest      PurchaseRequest[]
  RFI                  RFI[]
  StockMovement        StockMovement[]
  Submittal            Submittal[]
  WorkOrder            WorkOrder[]
  productivity_logs    productivity_logs[]
  resource_assignments resource_assignments[]
  resource_requests    resource_requests[]

  @@index([clientId])
  @@index([status])
}

model ProjectComment {
  id         String   @id
  projectId  String
  userId     String
  entityType String
  entityId   String?
  content    String
  mentions   String?
  createdAt  DateTime @default(now())
  Project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityId])
  @@index([entityType])
  @@index([projectId])
}

model ProjectCommitment {
  id            String    @id
  projectId     String
  type          String
  vendor        String
  description   String?
  contractValue Float     @default(0)
  committedCost Float     @default(0)
  remainingCost Float     @default(0)
  status        String    @default("draft")
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
}

model ProjectDocument {
  id         String   @id
  projectId  String
  name       String
  type       String
  filePath   String?
  fileSize   Int?
  mimeType   String?
  uploadedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([projectId])
}

model ProjectMember {
  id        String   @id
  projectId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

model ProjectMilestone {
  id          String    @id
  projectId   String
  name        String
  description String?
  dueDate     DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectTask {
  id                String        @id
  projectId         String
  title             String
  description       String?
  status            String        @default("todo")
  priority          String        @default("medium")
  startDate         DateTime?
  endDate           DateTime?
  progress          Float         @default(0)
  assigneeId        String?
  parentTaskId      String?
  order             Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  ProjectTask       ProjectTask?  @relation("ProjectTaskToProjectTask", fields: [parentTaskId], references: [id])
  other_ProjectTask ProjectTask[] @relation("ProjectTaskToProjectTask")
  User              User?         @relation(fields: [assigneeId], references: [id])
  Project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([assigneeId])
  @@index([status])
  @@index([projectId])
}

model ProjectTeamMember {
  id        String   @id
  projectId String
  name      String
  role      String
  company   String?
  phone     String?
  email     String?
  photo     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PurchaseOrder {
  id                String              @id
  projectId         String
  purchaseRequestId String?             @unique
  supplierId        String
  orderNo           String              @unique
  status            String              @default("draft")
  orderDate         DateTime
  expectedDate      DateTime?
  subtotal          Float               @default(0)
  tax               Float               @default(0)
  total             Float               @default(0)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  PurchaseRequest   PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id])
  Supplier          Supplier            @relation(fields: [supplierId], references: [id])
  Project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  PurchaseOrderItem PurchaseOrderItem[]

  @@index([status])
  @@index([supplierId])
  @@index([projectId])
}

model PurchaseOrderItem {
  id              String        @id
  purchaseOrderId String
  materialId      String?
  description     String
  quantity        Float
  receivedQty     Float         @default(0)
  unit            String
  unitPrice       Float
  amount          Float
  PurchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model PurchaseRequest {
  id                                      String                @id
  projectId                               String
  requestNo                               String                @unique
  status                                  String                @default("draft")
  requiredBy                              DateTime?
  notes                                   String?
  createdById                             String
  approvedById                            String?
  createdAt                               DateTime              @default(now())
  updatedAt                               DateTime
  PurchaseOrder                           PurchaseOrder?
  User_PurchaseRequest_approvedByIdToUser User?                 @relation("PurchaseRequest_approvedByIdToUser", fields: [approvedById], references: [id])
  User_PurchaseRequest_createdByIdToUser  User                  @relation("PurchaseRequest_createdByIdToUser", fields: [createdById], references: [id])
  Project                                 Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  PurchaseRequestItem                     PurchaseRequestItem[]

  @@index([status])
  @@index([projectId])
}

model PurchaseRequestItem {
  id                String          @id
  purchaseRequestId String
  materialId        String?
  description       String
  quantity          Float
  unit              String
  estimatedPrice    Float?
  PurchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model RFI {
  id            String       @id
  projectId     String
  rfiNo         String
  title         String
  description   String
  category      String
  priority      String       @default("medium")
  status        String       @default("draft")
  submittedById String
  assignedTo    String?
  dueDate       DateTime?
  answeredById  String?
  answeredAt    DateTime?
  closedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  Project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  RFIComment    RFIComment[]

  @@index([category])
  @@index([status])
  @@index([projectId])
}

model RFIComment {
  id        String   @id
  rfiId     String
  userId    String
  content   String
  createdAt DateTime @default(now())
  RFI       RFI      @relation(fields: [rfiId], references: [id], onDelete: Cascade)

  @@index([rfiId])
}

model SalesInvoice {
  id          String    @id
  invoiceNo   String    @unique
  customerId  String?
  quotationId String?
  userId      String?
  invoiceDate DateTime
  dueDate     DateTime?
  subtotal    Float     @default(0)
  tax         Float     @default(0)
  total       Float     @default(0)
  paidAmount  Float     @default(0)
  status      String    @default("draft")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  User        User?     @relation(fields: [userId], references: [id])
  Customer    Customer? @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([customerId])
}

model SalesQuotation {
  id         String   @id
  quoteNo    String   @unique
  customerId String
  validUntil DateTime
  subtotal   Float    @default(0)
  tax        Float    @default(0)
  total      Float    @default(0)
  status     String   @default("draft")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([status])
  @@index([customerId])
}

model Session {
  id           String    @id
  userId       String
  token        String    @unique
  refreshToken String?
  device       String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model StockMovement {
  id         String   @id
  projectId  String?
  materialId String
  type       String
  quantity   Float
  unitPrice  Float?
  reference  String?
  notes      String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  Project    Project? @relation(fields: [projectId], references: [id])
  Material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([projectId])
  @@index([materialId])
}

model SubContractor {
  id        String      @id
  name      String
  code      String      @unique
  contact   String?
  email     String?
  phone     String?
  address   String?
  gstNo     String?
  balance   Float       @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime
  WorkOrder WorkOrder[]

  @@index([isActive])
}

model Submittal {
  id            String    @id
  projectId     String
  submittalNo   String
  title         String
  specification String?
  category      String
  priority      String    @default("medium")
  revision      String    @default("0")
  status        String    @default("draft")
  submittedById String
  reviewedById  String?
  dueDate       DateTime?
  reviewedAt    DateTime?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([status])
  @@index([projectId])
}

model Supplier {
  id            String          @id
  name          String
  code          String          @unique
  contact       String?
  email         String?
  phone         String?
  address       String?
  gstNo         String?
  balance       Float           @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  PurchaseOrder PurchaseOrder[]

  @@index([isActive])
}

model SystemVersion {
  id           String   @id
  version      String   @unique
  title        String
  releaseNotes String
  releasedAt   DateTime @default(now())
  releasedBy   String?
}

model User {
  id                                                 String                  @id
  email                                              String                  @unique
  password                                           String
  name                                               String
  phone                                              String?
  avatar                                             String?
  role                                               String                  @default("labour")
  isActive                                           Boolean                 @default(true)
  isLocked                                           Boolean                 @default(false)
  lockoutUntil                                       DateTime?
  failedLoginAttempts                                Int                     @default(0)
  lastLoginAt                                        DateTime?
  totpSecret                                         String?
  totpEnabled                                        Boolean                 @default(false)
  createdAt                                          DateTime                @default(now())
  updatedAt                                          DateTime
  AssetIssue                                         AssetIssue[]
  AuditLog                                           AuditLog[]
  Budget_Budget_approvedByIdToUser                   Budget[]                @relation("Budget_approvedByIdToUser")
  Budget_Budget_createdByIdToUser                    Budget[]                @relation("Budget_createdByIdToUser")
  DailyNote                                          DailyNote[]
  Expense                                            Expense[]
  LeaveRequest_LeaveRequest_approvedByIdToUser       LeaveRequest[]          @relation("LeaveRequest_approvedByIdToUser")
  LeaveRequest_LeaveRequest_userIdToUser             LeaveRequest[]          @relation("LeaveRequest_userIdToUser")
  Notification                                       Notification[]
  NotificationPreference                             NotificationPreference?
  ProjectMember                                      ProjectMember[]
  ProjectTask                                        ProjectTask[]
  PurchaseRequest_PurchaseRequest_approvedByIdToUser PurchaseRequest[]       @relation("PurchaseRequest_approvedByIdToUser")
  PurchaseRequest_PurchaseRequest_createdByIdToUser  PurchaseRequest[]       @relation("PurchaseRequest_createdByIdToUser")
  SalesInvoice                                       SalesInvoice[]
  Session                                            Session[]
}

model WorkOrder {
  id               String             @id
  projectId        String
  subContractorId  String
  orderNo          String
  description      String
  totalAmount      Float
  retentionPercent Float              @default(10)
  status           String             @default("draft")
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  MilestonePayment MilestonePayment[]
  SubContractor    SubContractor      @relation(fields: [subContractorId], references: [id], onDelete: Cascade)
  Project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([subContractorId])
  @@index([projectId])
}

model crew_members {
  id         String   @id
  crewId     String
  workerType String
  workerId   String
  workerName String
  role       String   @default("member")
  joinDate   DateTime @default(now())
  isActive   Boolean  @default(true)
  crews      crews    @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, workerType, workerId])
}

model crews {
  id           String         @id
  name         String
  type         String
  leaderName   String?
  leaderId     String?
  leaderType   String?
  description  String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  crew_members crew_members[]
}

model productivity_logs {
  id           String   @id
  projectId    String
  date         DateTime
  resourceType String
  resourceId   String?
  crewId       String?
  resourceName String?
  task         String?
  outputUnit   String?
  outputQty    Float    @default(0)
  hoursWorked  Float    @default(0)
  cost         Float    @default(0)
  quality      String?
  notes        String?
  createdById  String
  createdAt    DateTime @default(now())
  Project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([resourceType])
  @@index([projectId, date])
}

model resource_assignments {
  id           String    @id
  projectId    String
  resourceType String
  resourceId   String
  resourceName String
  role         String?
  shift        String    @default("day")
  location     String?
  startDate    DateTime
  endDate      DateTime?
  status       String    @default("active")
  dailyCost    Float     @default(0)
  hourlyCost   Float     @default(0)
  notes        String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  Project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([startDate])
  @@index([status])
  @@index([resourceType, resourceId])
  @@index([projectId])
}

model resource_requests {
  id                     String    @id
  projectId              String
  requestNo              String
  resourceType           String
  resourceName           String?
  quantity               Int       @default(1)
  trade                  String?
  requiredSkills         String?
  startDate              DateTime?
  endDate                DateTime?
  shift                  String    @default("day")
  priority               String    @default("medium")
  reason                 String?
  status                 String    @default("pending")
  requestedById          String
  supervisorApprovedById String?
  supervisorApprovedAt   DateTime?
  pmApprovedById         String?
  pmApprovedAt           DateTime?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime
  Project                Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
}

model skills {
  id            String          @id
  name          String          @unique
  category      String?
  description   String?
  createdAt     DateTime        @default(now())
  worker_skills worker_skills[]
}

model worker_skills {
  id          String    @id
  skillId     String
  workerType  String
  workerId    String
  proficiency String    @default("intermediate")
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  skills      skills    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, workerType, workerId])
}
