generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AIInsight {
  id               String    @id @default(uuid())
  projectId        String?
  insightType      String
  title            String
  description      String     @db.Text
  confidence       Float     @default(0)
  severity         String    @default("info")
  recommendations  String     @db.Text
  affectedEntities String?
  status           String    @default("new")
  createdById      String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?
  project          Project?  @relation(fields: [projectId], references: [id])
  user             User?     @relation("AIInsight_createdByIdToUser", fields: [createdById], references: [id])

  @@index([severity])
  @@index([status])
  @@index([insightType])
  @@index([projectId])
}

model AdvancePayment {
  id        String   @id @default(uuid())
  labourId  String
  amount    Float
  date      DateTime
  reason    String? @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  labour    Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([labourId])
}

model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String @db.Text
  category    String
  priority    String    @default("normal")
  targetScope String    @default("all")
  projectId   String?
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  project     Project?  @relation(fields: [projectId], references: [id])
  user        User      @relation("Announcement_createdByIdToUser", fields: [createdById], references: [id])

  @@index([targetScope])
  @@index([createdAt])
  @@index([priority])
  @@index([category])
}

model Asset {
  id               String             @id @default(uuid())
  name             String
  code             String             @unique
  type             String
  category         String?
  purchaseDate     DateTime?
  purchasePrice    Float
  currentValue     Float
  status           String             @default("available")
  location         String?
  qrCode           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime @updatedAt
  issues           AssetIssue[]
  assetMaintenance AssetMaintenance[]
  maintenanceTickets MaintenanceTicket[]

  @@index([name])
  @@index([status])
  @@index([type])
}

model AssetIssue {
  id         String    @id @default(uuid())
  assetId    String
  issuedTo   String
  issuedById String
  issuedDate DateTime
  returnDate DateTime?
  status     String    @default("issued")
  notes      String? @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime @updatedAt
  user       User @relation(fields: [issuedById], references: [id])
  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assetId])
  @@index([issuedById])
}

model AssetMaintenance {
  id            String    @id @default(uuid())
  assetId       String
  type          String
  description   String @db.Text
  cost          Float     @default(0)
  date          DateTime
  vendor        String?
  status        String    @default("pending")
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt
  asset         Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assetId])
}

model Attendance {
  id          String   @id @default(uuid())
  projectId   String
  labourId    String
  date        DateTime
  status      String   @default("present")
  hoursWorked Float?
  overtime    Float?
  verifiedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  labour      Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@unique([projectId, labourId, date])
  @@index([date])
  @@index([labourId])
  @@index([projectId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues String? @db.Text
  newValues String? @db.Text
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([entity])
}

model BOQ {
  id        String    @id @default(uuid())
  projectId String    @unique
  version   Int       @default(1)
  total     Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items     BOQItem[]

  @@index([projectId])
}

model BOQItem {
  id          String @id @default(uuid())
  boqId       String
  itemNo      String
  description String @db.Text
  boq         BOQ    @relation(fields: [boqId], references: [id], onDelete: Cascade)

  @@index([boqId])
}

model Budget {
  id                             String              @id @default(uuid())
  projectId                      String              @unique
  originalValue                  Float               @default(0)
  revisedValue                   Float               @default(0)
  approvedChanges                Float               @default(0)
  pendingChanges                 Float               @default(0)
  retentionPercent               Float               @default(10)
  retentionReleased              Float               @default(0)
  status                         String              @default("draft")
  createdById                    String
  approvedById                   String?
  approvedAt                     DateTime?
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime @updatedAt
  approvedBy                     User?               @relation("Budget_approvedByIdToUser", fields: [approvedById], references: [id])
  createdBy                      User                @relation("Budget_createdByIdToUser", fields: [createdById], references: [id])
  project                        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetChangeOrder              BudgetChangeOrder[]
  budgetLineItem                 BudgetLineItem[]
  budgetSnapshot                 BudgetSnapshot[]

  @@index([status])
  @@index([projectId])
}

model BudgetChangeOrder {
  id                   String                 @id @default(uuid())
  budgetId             String
  bcoNo                String
  title                String
  description          String? @db.Text
  reason               String? @db.Text
  changeAmount         Float                  @default(0)
  newBudget            Float                  @default(0)
  status               String                 @default("draft")
  submittedById        String
  reviewedById         String?
  approvedById         String?
  reviewedAt           DateTime?
  approvedAt           DateTime?
  appliedAt            DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime @updatedAt
  budget               Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  lineItemUpdates      BudgetLineItemUpdate[]

  @@index([status])
  @@index([budgetId])
}

model BudgetLineItem {
  id                    String   @id @default(uuid())
  budgetId              String
  costCodeId            String
  originalBudget        Float    @default(0)
  revisedBudget         Float    @default(0)
  committedCost         Float    @default(0)
  actualCost            Float    @default(0)
  forecastToComplete    Float    @default(0)
  estimatedAtCompletion Float    @default(0)
  percentComplete       Float    @default(0)
  earnedRevenue         Float    @default(0)
  billedRevenue         Float    @default(0)
  notes                 String? @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  costCode              CostCode @relation(fields: [costCodeId], references: [id])
  budget                Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  lineItemUpdates       BudgetLineItemUpdate[]

  @@index([costCodeId])
  @@index([budgetId])
}

model BudgetLineItemUpdate {
  id                  String            @id @default(uuid())
  budgetChangeOrderId String
  budgetLineItemId    String
  previousAmount      Float             @default(0)
  newAmount           Float             @default(0)
  changeAmount        Float             @default(0)
  budgetChangeOrder   BudgetChangeOrder @relation(fields: [budgetChangeOrderId], references: [id], onDelete: Cascade)
  budgetLineItem      BudgetLineItem    @relation(fields: [budgetLineItemId], references: [id], onDelete: Cascade)

  @@index([budgetLineItemId])
  @@index([budgetChangeOrderId])
}

model BudgetSnapshot {
  id             String   @id @default(uuid())
  budgetId       String
  name           String
  snapshotType   String
  totalBudget    Float    @default(0)
  totalActual    Float    @default(0)
  totalCommitted Float    @default(0)
  totalForecast  Float    @default(0)
  totalEarned    Float    @default(0)
  totalBilled    Float    @default(0)
  snapshotData   String @db.Text
  createdById    String
  createdAt      DateTime @default(now())
  user           User     @relation("BudgetSnapshot_createdByIdToUser", fields: [createdById], references: [id])
  budget         Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([snapshotType])
  @@index([budgetId])
}

model ChangeEvent {
  id                      String        @id @default(uuid())
  projectId               String
  eventNo                 String
  title                   String
  description             String? @db.Text
  category                String
  impactType              String
  potentialCostImpact     Float         @default(0)
  potentialScheduleImpact String?
  status                  String        @default("draft")
  submittedById           String
  reviewedById            String?
  approvedById            String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime @updatedAt
  project                 Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeOrder             ChangeOrder[]

  @@index([status])
  @@index([projectId])
}

model ChangeOrder {
  id             String       @id @default(uuid())
  projectId      String
  changeEventId  String?
  coNo           String
  title          String
  description    String? @db.Text
  costAdjustment Float        @default(0)
  timeAdjustment String?
  originalBudget Float        @default(0)
  adjustedBudget Float        @default(0)
  status         String       @default("draft")
  submittedById  String
  approvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime @updatedAt
  changeEvent    ChangeEvent? @relation(fields: [changeEventId], references: [id])
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
}

model ClientComplaint {
  id                 String    @id @default(uuid())
  ticketNumber       String?   @unique
  projectId          String
  clientName         String
  subject            String
  description        String    @db.Text
  category           String
  severity           String    @default("medium")
  status             String    @default("open")
  workflowStage      String    @default("received")
  source             String    @default("portal")
  assignedTo         String?
  resolvedById       String?
  resolution         String?   @db.Text
  resolutionDate     DateTime?
  responseDeadline   DateTime?
  resolutionDeadline DateTime?
  slaBreached        Boolean   @default(false)
  lastActivityAt     DateTime  @default(now())
  idempotencyKey     String?   @unique
  createdById        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation("ClientComplaint_createdByIdToUser", fields: [createdById], references: [id])
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([severity])
  @@index([category])
  @@index([status])
  @@index([projectId])
  @@index([workflowStage])
  @@index([slaBreached])
  @@index([source])
  @@index([lastActivityAt])
}

model CostCode {
  id             String           @id @default(uuid())
  code           String           @unique
  name           String
  level          Int              @default(1)
  parentId       String?
  description    String? @db.Text
  unitType       String?
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  budgetItems    BudgetLineItem[]
  parent         CostCode?        @relation("CostCodeToCostCode", fields: [parentId], references: [id], onDelete: Cascade)
  children       CostCode[]       @relation("CostCodeToCostCode")

  @@index([sortOrder])
  @@index([isActive])
  @@index([level])
  @@index([parentId])
}

model Customer {
  id             String           @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String? @db.Text
  gstNo          String?
  balance        Float            @default(0)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  salesInvoice   SalesInvoice[]
  salesQuotation SalesQuotation[]
  maintenanceTickets MaintenanceTicket[]
  maintenanceWorkOrders MaintenanceWorkOrder[]
  whatsappContacts   WhatsAppContact[]
  maintenanceSites   MaintenanceSite[]
  pmSchedules        PMSchedule[]
  maintenanceInvoices MaintenanceInvoice[]
  amcContracts       AMCContract[]

  @@index([isActive])
}

model DailyNote {
  id           String   @id @default(uuid())
  projectId    String
  date         DateTime
  weather      String?
  temperature  Float?
  workDone     String? @db.Text
  issues       String? @db.Text
  supervisorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User @relation(fields: [supervisorId], references: [id])
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([projectId])
}

model DayBookEntry {
  id          String   @id @default(uuid())
  date        DateTime
  description String @db.Text
  category    String
  type        String
  amount      Float
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([category])
  @@index([type])
  @@index([date])
}

model DirectCost {
  id           String   @id @default(uuid())
  projectId    String
  category     String
  description  String @db.Text
  amount       Float
  date         DateTime
  approvedById String?
  receipt      String?
  status       String   @default("pending")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("DirectCost_createdByIdToUser", fields: [createdById], references: [id])
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([category])
  @@index([projectId])
}

model Discussion {
  id                String              @id @default(uuid())
  projectId         String
  title             String
  description       String? @db.Text
  category          String
  status            String              @default("open")
  priority          String              @default("medium")
  createdById       String
  assignedTo        String?
  dueDate           DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime @updatedAt
  user              User                @relation("Discussion_createdByIdToUser", fields: [createdById], references: [id])
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  discussionComment DiscussionComment[]

  @@index([category])
  @@index([status])
  @@index([projectId])
}

model DiscussionComment {
  id           String     @id @default(uuid())
  discussionId String
  userId       String
  content      String     @db.Text
  createdAt    DateTime   @default(now())
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
}

model Employee {
  id           String         @id @default(uuid())
  userId       String?        @unique
  empCode      String         @unique
  name         String
  email        String?
  phone        String?
  department   String?
  designation  String?
  joinDate     DateTime?
  basicSalary  Float
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime @updatedAt
  leaveRequests LeaveRequest[]
  loan         Loan[]
  technicianProfiles TechnicianProfile[]

  @@index([isActive])
}

model Expense {
  id          String   @id @default(uuid())
  projectId   String
  category    String
  description String @db.Text
  amount      Float
  date        DateTime
  approvedBy  String?
  createdById String
  receipt     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([category])
  @@index([projectId])
  @@index([createdById])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String? @db.Text
  module      String
  enabled     Boolean  @default(true)
  isBeta      Boolean  @default(false)
  config      String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id          String        @id @default(uuid())
  projectId   String
  invoiceNo   String        @unique
  clientId    String?
  type        String        @default("sales")
  status      String        @default("draft")
  issueDate   DateTime
  dueDate     DateTime?
  subtotal    Float         @default(0)
  tax         Float         @default(0)
  discount    Float         @default(0)
  total       Float         @default(0)
  paidAmount  Float         @default(0)
  retention   Float         @default(0)
  notes       String?       @db.Text
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoiceItem InvoiceItem[]
  payment     Payment[]

  @@index([issueDate])
  @@index([status])
  @@index([projectId])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String  @db.Text
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Labour {
  id             String           @id @default(uuid())
  groupId        String
  name           String
  phone          String?
  aadhaar        String?
  dailyRate      Float
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  advancePayment AdvancePayment[]
  attendance     Attendance[]
  group          LabourGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payroll        Payroll[]

  @@index([isActive])
  @@index([groupId])
}

model LabourGroup {
  id        String   @id @default(uuid())
  name      String
  rate      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  labours   Labour[]

  @@index([isActive])
}

model LeaveRequest {
  id                                   String   @id @default(uuid())
  employeeId                           String
  userId                               String?
  type                                 String
  startDate                            DateTime
  endDate                              DateTime
  days                                 Float
  reason                               String? @db.Text
  status                               String   @default("pending")
  approvedById                         String?
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime @updatedAt
  approvedBy                           User?    @relation("LeaveRequest_approvedByIdToUser", fields: [approvedById], references: [id])
  User_LeaveRequest_userIdToUser       User?    @relation("LeaveRequest_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
  employee                             Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([employeeId])
}

model Loan {
  id           String   @id @default(uuid())
  employeeId   String
  amount       Float
  interestRate Float    @default(0)
  tenureMonths Int      @default(0)
  emiAmount    Float    @default(0)
  startDate    DateTime
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([employeeId])
}

model Material {
  id            String          @id @default(uuid())
  name          String
  code          String          @unique
  unit          String
  category      String?
  description   String? @db.Text
  currentStock  Float           @default(0)
  minStock      Float           @default(0)
  unitPrice     Float           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime @updatedAt
  stockMovement StockMovement[]

  @@index([name])
}

model MilestonePayment {
  id          String    @id @default(uuid())
  workOrderId String
  description String @db.Text
  amount      Float
  retention   Float     @default(0)
  netAmount   Float
  dueDate     DateTime?
  paidDate    DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([workOrderId])
}

model Notification {
  id            String             @id @default(uuid())
  userId        String
  type          String
  title         String
  message       String             @db.Text
  data          String?            @db.Text
  link          String?
  category      String?
  priority      String             @default("normal")
  companyId     String?
  branchId      String?
  module        String?
  referenceType String?
  referenceId   String?
  createdBy     String?
  isRead        Boolean            @default(false)
  readAt        DateTime?
  clickedAt     DateTime?
  dismissedAt   DateTime?
  deliveredAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt @default(now())
  deletedAt     DateTime?
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reads         NotificationRead[]

  @@index([createdAt])
  @@index([isRead])
  @@index([userId])
  @@index([category])
  @@index([priority])
  @@index([userId, isRead, deletedAt])
  @@index([userId, deletedAt, createdAt])
}

model NotificationRead {
  id             String       @id @default(uuid())
  notificationId String
  userId         String
  read           Boolean      @default(true)
  readAt         DateTime     @default(now())
  clickedAt      DateTime?
  dismissedAt    DateTime?
  deviceId       String?
  browser        String?
  ipAddress      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notificationId, userId])
  @@index([userId, read])
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  inApp     Boolean  @default(true)
  email     Boolean  @default(true)
  sms       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OpenItem {
  id           String    @id @default(uuid())
  projectId    String
  itemNo       String
  title        String
  description  String? @db.Text
  category     String
  priority     String    @default("medium")
  status       String    @default("open")
  assignedTo   String?
  dueDate      DateTime?
  resolvedDate DateTime?
  resolvedById String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime @updatedAt
  user         User      @relation("OpenItem_createdByIdToUser", fields: [createdById], references: [id])
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([status])
  @@index([category])
  @@index([projectId])
}

model Payment {
  id         String   @id @default(uuid())
  projectId  String
  invoiceId  String?
  paymentNo  String
  amount     Float
  method     String
  status     String   @default("pending")
  reference  String?
  date       DateTime
  receivedBy String?
  notes      String? @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([invoiceId])
  @@index([projectId])
}

model Payroll {
  id                String    @id @default(uuid())
  projectId         String
  labourId          String
  periodStart       DateTime
  periodEnd         DateTime
  daysWorked        Int       @default(0)
  overtimeHours     Float     @default(0)
  basicPay          Float     @default(0)
  overtimePay       Float     @default(0)
  deductions        Float     @default(0)
  advanceDeductions Float     @default(0)
  netPay            Float     @default(0)
  status            String    @default("pending")
  paidDate          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime @updatedAt
  labour            Labour @relation(fields: [labourId], references: [id], onDelete: Cascade)

  @@index([periodStart])
  @@index([labourId])
  @@index([projectId])
}

model PrimeContract {
  id              String    @id @default(uuid())
  projectId       String    @unique
  contractNo      String
  client          String
  originalValue   Float     @default(0)
  variationOrders Float     @default(0)
  retention       Float     @default(0)
