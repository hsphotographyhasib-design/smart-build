# Copy to .env and fill in. Do NOT commit your real .env.

# Database — XAMPP MySQL (see prisma/schema.prisma provider = "mysql")
DATABASE_URL="mysql://root:@127.0.0.1:3306/smartbuild_eppm"

# --- Auth ---
# Long random string used to sign session JWTs. Generate your own for production.
AUTH_SECRET="change-me-to-a-long-random-string"
# Base URL of the app (used to build OAuth redirect URIs).
APP_URL="http://localhost:3000"

# --- Google OAuth (optional) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- WhatsApp OTP (optional) ---
# Left blank -> dev stub (the code is shown in the UI / server console).
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
