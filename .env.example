# Copy to .env and fill in. Do NOT commit your real .env.

# Database (Prisma Postgres / any Postgres). Use your own connection string.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# --- Auth ---
# Long random string used to sign session JWTs. Generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Base URL of the app — used to build the OAuth redirect URI.
# Local dev:   http://localhost:3000
# Production:  https://app.hasanurjaya.com
APP_URL="http://localhost:3000"

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins:
#   http://localhost:3000
#   https://app.hasanurjaya.com
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/google/callback
#   https://app.hasanurjaya.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- WhatsApp OTP (optional) ---
# Left blank -> dev stub (the code is shown in the UI / server console).
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
